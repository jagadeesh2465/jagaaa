import java.util.Optional;

import org.apache.commons.lang3.exception.ExceptionUtils;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.actuate.health.Health;
import org.springframework.boot.actuate.health.HealthIndicator;
import org.springframework.stereotype.Component;

import com.hazelcast.core.HazelcastInstance;

import lombok.extern.slf4j.Slf4j;

@Slf4j
@Component(“hazelcastHealthIndicator”)
public class HazelcastHealthIndicator implements HealthIndicator {

```
private final Optional<HazelcastInstance> hazelcastInstance;

public HazelcastHealthIndicator(
		@Autowired(required = false) HazelcastInstance hazelcastInstance) {
	this.hazelcastInstance = Optional.ofNullable(hazelcastInstance);
	log.info("HazelcastHealthIndicator initialized with instance present: {}",
			this.hazelcastInstance.isPresent());
}

@Override
public Health health() {
	try {
		if (hazelcastInstance.isEmpty()) {
			log.warn("Hazelcast instance not available - reporting UNKNOWN status");
			return Health.unknown()
					.withDetail("status", "Hazelcast not configured or disabled")
					.withDetail("reason", "No HazelcastInstance bean found")
					.build();
		}

		HazelcastInstance instance = hazelcastInstance.get();

		// Check if Hazelcast is running
		if (instance.getLifecycleService().isRunning()) {
			log.debug("Hazelcast instance is running - reporting UP status");
			return Health.up()
					.withDetail("name", instance.getName())
					.withDetail("memberCount", instance.getCluster().getMembers().size())
					.withDetail("status", "Running")
					.build();
		} else {
			log.warn("Hazelcast instance exists but is not running - reporting DOWN status");
			return Health.down()
					.withDetail("name", instance.getName())
					.withDetail("status", "Not running")
					.withDetail("reason", "Lifecycle service indicates instance is not running")
					.build();
		}

	} catch (Exception e) {
		log.error("Error checking Hazelcast health: {} cause: {}", e.getMessage(),
				ExceptionUtils.getStackTrace(e).replaceAll("\\r?\\n", " "));
		return Health.down()
				.withException(e)
				.withDetail("error", e.getMessage())
				.withDetail("status", "Health check failed")
				.build();
	}
}
