package com.creditone.ucrm.autopaysynch.processor;

import org.springframework.boot.context.properties.EnableConfigurationProperties;
import org.springframework.cloud.context.config.annotation.RefreshScope;
import org.springframework.stereotype.Component;

import com.hazelcast.nio.serialization.genericrecord.GenericRecord;

import com.creditone.ucrm.autopaysynch.config.CustomerMappingPropertiesConfig;
import com.creditone.ucrm.autopaysynch.constant.AutoPaySynchConstant;
import com.creditone.ucrm.autopaysynch.constant.AutoPaySynchConstant.SyncType;
import com.creditone.ucrm.autopaysynch.service.ExternalCallService;

import lombok.extern.slf4j.Slf4j;
import reactor.core.publisher.Mono;

/**
 * Processor for resolving modern/legacy Customer IDs.
 * Strategy:
 *   1. Try Hazelcast cache first (fast path)
 *   2. Fall back to ExternalCallService (CIAM / Customer Domain Service) if not found
 *
 * Follows the same pattern as AgentLookupProcessor in debit-card-payment-sync-service.
 * Referenced in lead's instructions:
 *   CustomerMappingProcessor -> getModernCustomerId(legacyCustomerId) -> hazelcast -> fallback
 */
@Slf4j
@Component
@RefreshScope
@EnableConfigurationProperties(CustomerMappingPropertiesConfig.class)
public class CustomerMappingProcessor extends AbstractHazelcastLookupProcessor<String> {

	private final CustomerMappingPropertiesConfig config;

	public CustomerMappingProcessor(HazelcastWrapperProcessor hazelcastWrapperProcessor, ExternalCallService externalCallService, CustomerMappingPropertiesConfig config) {
		super(hazelcastWrapperProcessor, externalCallService);
		this.config = config;
	}

	/**
	 * Resolves the modern customer UUID for a given legacy customer ID.
	 * Tries Hazelcast first, falls back to ExternalCallService (CIAM).
	 *
	 * @param legacyCustomerId the legacy customer ID
	 * @param correlationId    for distributed tracing
	 * @return Mono of modern customer UUID string
	 */
	public Mono<String> getModernCustomerId(String legacyCustomerId, String correlationId) {
		log.info(AutoPaySynchConstant.LOG_PREFIX + "Resolving modern customer ID for legacyCustomerId: {}", correlationId, legacyCustomerId);
		return convertId(legacyCustomerId, SyncType.LEGACY_TO_MODERN, correlationId);
	}

	@Override
	protected String getMapName(SyncType syncType) {
		return syncType == SyncType.MODERN_TO_LEGACY ? config.getModernToLegacy().getMapName() : config.getLegacyToModern().getMapName();
	}

	@Override
	protected String getKeyName(SyncType syncType) {
		return syncType == SyncType.MODERN_TO_LEGACY ? config.getModernToLegacy().getKeyName() : config.getLegacyToModern().getKeyName();
	}

	@Override
	protected String getEntityType() {
		return "CUSTOMER";
	}

	@Override
	protected Mono<String> processRecord(GenericRecord record, SyncType syncType, String correlationId, String keyName) {
		String customerId = record.getString(keyName);
		if (customerId == null || customerId.trim().isEmpty()) {
			log.warn(AutoPaySynchConstant.LOG_PREFIX + "Customer ID is null or empty for keyName '{}' for {}", correlationId, keyName, syncType);
			return Mono.empty();
		}

		log.info(AutoPaySynchConstant.LOG_PREFIX + "Successfully retrieved customer ID for {} from Hazelcast: {}", correlationId, syncType, customerId);
		return Mono.just(customerId.trim());
	}

	@Override
	protected Mono<String> callExternalService(String key, SyncType syncType, String correlationId) {
		return externalCallService.convertCustomerId(key, syncType, correlationId);
	}

}









