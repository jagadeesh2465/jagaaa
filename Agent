package com.creditone.ucrm.autopaysynch.processor;

import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.ArgumentMatchers.*;
import static org.mockito.Mockito.*;

import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import org.mockito.junit.jupiter.MockitoSettings;
import org.mockito.quality.Strictness;

import com.hazelcast.map.IMap;
import com.hazelcast.nio.serialization.genericrecord.GenericRecord;
import com.creditone.ucrm.autopaysynch.config.AgentMappingPropertiesConfig;
import com.creditone.ucrm.autopaysynch.constant.AutoPaySynchConstant.SyncType;
import com.creditone.ucrm.autopaysynch.exception.AutoPaySynchException;
import com.creditone.ucrm.autopaysynch.service.ExternalCallService;

import reactor.core.publisher.Mono;
import reactor.test.StepVerifier;

@SuppressWarnings({“unchecked”, “rawtypes”})
@ExtendWith(MockitoExtension.class)
@MockitoSettings(strictness = Strictness.LENIENT)
class AgentMappingProcessorTest {

```
@Mock
private HazelcastWrapperProcessor hazelcastWrapperProcessor;

@Mock
private ExternalCallService externalCallService;

@Mock
private AgentMappingPropertiesConfig config;

@Mock
private AgentMappingPropertiesConfig.MapConfig legacyToModernConfig;

@Mock
private AgentMappingPropertiesConfig.MapConfig modernToLegacyConfig;

@Mock
private IMap map;

@Mock
private GenericRecord genericRecord;

private AgentMappingProcessor agentMappingProcessor;

private static final String LEGACY_AGENT_ID = "AG-001";
private static final String MODERN_AGENT_UUID = "uuid-agent-xyz-456";
private static final String CORRELATION_ID = "corr-test-001";
private static final String LTM_MAP_NAME = "AUTOPAY_AGENT_LTM_MAP";
private static final String MTL_MAP_NAME = "AUTOPAY_AGENT_MTL_MAP";
private static final String LTM_KEY_NAME = "modernAgentId";
private static final String MTL_KEY_NAME = "legacyAgentId";

@BeforeEach
void setUp() {
	lenient().when(config.getLegacyToModern()).thenReturn(legacyToModernConfig);
	lenient().when(config.getModernToLegacy()).thenReturn(modernToLegacyConfig);
	lenient().when(legacyToModernConfig.getMapName()).thenReturn(LTM_MAP_NAME);
	lenient().when(legacyToModernConfig.getKeyName()).thenReturn(LTM_KEY_NAME);
	lenient().when(modernToLegacyConfig.getMapName()).thenReturn(MTL_MAP_NAME);
	lenient().when(modernToLegacyConfig.getKeyName()).thenReturn(MTL_KEY_NAME);

	agentMappingProcessor = new AgentMappingProcessor(
			hazelcastWrapperProcessor, externalCallService, config);
}

// ==================== getModernAgentId ====================

@Test
void testGetModernAgentId_WhenHazelcastHit_ReturnsModernId() {
	when(hazelcastWrapperProcessor.getMap(LTM_MAP_NAME, CORRELATION_ID)).thenReturn(map);
	when(map.get(LEGACY_AGENT_ID)).thenReturn(genericRecord);
	when(genericRecord.getString(LTM_KEY_NAME)).thenReturn(MODERN_AGENT_UUID);

	StepVerifier.create(
			agentMappingProcessor.getModernAgentId(LEGACY_AGENT_ID, CORRELATION_ID))
			.expectNext(MODERN_AGENT_UUID)
			.verifyComplete();

	verify(externalCallService, never()).convertAgentId(any(), any(), any());
}

@Test
void testGetModernAgentId_WhenHazelcastMiss_CallsExternalService() {
	when(hazelcastWrapperProcessor.getMap(LTM_MAP_NAME, CORRELATION_ID)).thenReturn(null);
	when(externalCallService.convertAgentId(
			LEGACY_AGENT_ID, SyncType.LEGACY_TO_MODERN, CORRELATION_ID))
			.thenReturn(Mono.just(MODERN_AGENT_UUID));

	StepVerifier.create(
			agentMappingProcessor.getModernAgentId(LEGACY_AGENT_ID, CORRELATION_ID))
			.expectNext(MODERN_AGENT_UUID)
			.verifyComplete();

	verify(externalCallService, times(1))
			.convertAgentId(LEGACY_AGENT_ID, SyncType.LEGACY_TO_MODERN, CORRELATION_ID);
}

@Test
void testGetModernAgentId_WhenMapExistsButKeyNotFound_CallsExternalService() {
	when(hazelcastWrapperProcessor.getMap(LTM_MAP_NAME, CORRELATION_ID)).thenReturn(map);
	when(map.get(LEGACY_AGENT_ID)).thenReturn(null);
	when(externalCallService.convertAgentId(
			LEGACY_AGENT_ID, SyncType.LEGACY_TO_MODERN, CORRELATION_ID))
			.thenReturn(Mono.just(MODERN_AGENT_UUID));

	StepVerifier.create(
			agentMappingProcessor.getModernAgentId(LEGACY_AGENT_ID, CORRELATION_ID))
			.expectNext(MODERN_AGENT_UUID)
			.verifyComplete();

	verify(externalCallService, times(1))
			.convertAgentId(LEGACY_AGENT_ID, SyncType.LEGACY_TO_MODERN, CORRELATION_ID);
}

@Test
void testGetModernAgentId_WhenRecordFoundButValueEmpty_FallsBackToExternalService() {
	when(hazelcastWrapperProcessor.getMap(LTM_MAP_NAME, CORRELATION_ID)).thenReturn(map);
	when(map.get(LEGACY_AGENT_ID)).thenReturn(genericRecord);
	when(genericRecord.getString(LTM_KEY_NAME)).thenReturn(null);
	when(externalCallService.convertAgentId(
			LEGACY_AGENT_ID, SyncType.LEGACY_TO_MODERN, CORRELATION_ID))
			.thenReturn(Mono.just(MODERN_AGENT_UUID));

	StepVerifier.create(
			agentMappingProcessor.getModernAgentId(LEGACY_AGENT_ID, CORRELATION_ID))
			.expectNext(MODERN_AGENT_UUID)
			.verifyComplete();

	verify(externalCallService, times(1))
			.convertAgentId(LEGACY_AGENT_ID, SyncType.LEGACY_TO_MODERN, CORRELATION_ID);
}

@Test
void testGetModernAgentId_WhenBothFail_ReturnsError() {
	when(hazelcastWrapperProcessor.getMap(LTM_MAP_NAME, CORRELATION_ID)).thenReturn(null);
	when(externalCallService.convertAgentId(
			LEGACY_AGENT_ID, SyncType.LEGACY_TO_MODERN, CORRELATION_ID))
			.thenReturn(Mono.error(
					new AutoPaySynchException("Agent not found", CORRELATION_ID)));

	StepVerifier.create(
			agentMappingProcessor.getModernAgentId(LEGACY_AGENT_ID, CORRELATION_ID))
			.expectError(AutoPaySynchException.class)
			.verify();
}

// ==================== getMapName ====================

@Test
void testGetMapName_LegacyToModern_ReturnsLtmMapName() {
	assertEquals(LTM_MAP_NAME, agentMappingProcessor.getMapName(SyncType.LEGACY_TO_MODERN));
}

@Test
void testGetMapName_ModernToLegacy_ReturnsMtlMapName() {
	assertEquals(MTL_MAP_NAME, agentMappingProcessor.getMapName(SyncType.MODERN_TO_LEGACY));
}

// ==================== getKeyName ====================

@Test
void testGetKeyName_LegacyToModern_ReturnsLtmKeyName() {
	assertEquals(LTM_KEY_NAME, agentMappingProcessor.getKeyName(SyncType.LEGACY_TO_MODERN));
}

@Test
void testGetKeyName_ModernToLegacy_ReturnsMtlKeyName() {
	assertEquals(MTL_KEY_NAME, agentMappingProcessor.getKeyName(SyncType.MODERN_TO_LEGACY));
}

// ==================== getEntityType ====================

@Test
void testGetEntityType_ReturnsAgent() {
	assertEquals("AGENT", agentMappingProcessor.getEntityType());
}
```

}
