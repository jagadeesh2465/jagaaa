package com.creditone.ucrm.autopaysynch.processor;

import org.springframework.boot.context.properties.EnableConfigurationProperties;
import org.springframework.cloud.context.config.annotation.RefreshScope;
import org.springframework.stereotype.Component;
import org.springframework.util.StringUtils;

import com.creditone.swagger.ciam.dtoswagger.SystemLinkagesResponse;
import com.creditone.swagger.ciam.dtoswagger.SystemLinkagesResponse.ContentInner;
import com.creditone.ucrm.autopaysynch.config.CustomerMappingPropertiesConfig;
import com.creditone.ucrm.autopaysynch.constant.AutoPaySynchConstant;
import com.creditone.ucrm.autopaysynch.constant.AutoPaySynchConstant.SyncType;
import com.creditone.ucrm.autopaysynch.exception.AutoPaySynchException;
import com.creditone.ucrm.autopaysynch.service.ExternalCallService;
import com.hazelcast.nio.serialization.genericrecord.GenericRecord;

import lombok.extern.slf4j.Slf4j;
import reactor.core.publisher.Mono;

import java.util.LinkedMultiValueMap;
import java.util.List;
import java.util.Map;
import java.util.Objects;

/**
 * Processor for resolving modern Customer IDs from legacy Customer IDs.
 * Strategy:
 *   1. Try Hazelcast cache first (fast path)
 *   2. Fall back to Customer Domain Service if not found
 *
 * Lead's requirement:
 *   CustomerMappingProcessor -> getModernCustomerId(legacyCustomerId) -> hazelcast -> externalcallservice -> fallback
 */
@Slf4j
@Component
@RefreshScope
@EnableConfigurationProperties(CustomerMappingPropertiesConfig.class)
public class CustomerMappingProcessor extends AbstractHazelcastLookupProcessor<String> {

	private final CustomerMappingPropertiesConfig config;
	private final ExternalCallService externalCallService;
	private final AutoPaySyncClientHandler autoPaySyncClientHandler;

	@org.springframework.beans.factory.annotation.Value("${external-service.customer-domain.host}")
	private String customerDomainHost;

	@org.springframework.beans.factory.annotation.Value("${external-service.customer-domain.system-linkages-uri}")
	private String systemLinkagesUri;

	@org.springframework.beans.factory.annotation.Value("${external-service.customer-domain.apikey}")
	private String customerDomainApiKey;

	public CustomerMappingProcessor(HazelcastWrapperProcessor hazelcastWrapperProcessor,
			ExternalCallService externalCallService,
			AutoPaySyncClientHandler autoPaySyncClientHandler,
			CustomerMappingPropertiesConfig config) {
		super(hazelcastWrapperProcessor, externalCallService);
		this.config = config;
		this.externalCallService = externalCallService;
		this.autoPaySyncClientHandler = autoPaySyncClientHandler;
	}

	/**
	 * Resolves the modern customer UUID for a given legacy customer ID.
	 * Tries Hazelcast first, falls back to Customer Domain Service.
	 *
	 * @param legacyCustomerId the legacy customer ID
	 * @param correlationId    for distributed tracing
	 * @return Mono of modern customer UUID string
	 */
	public Mono<String> getModernCustomerId(String legacyCustomerId, String correlationId) {
		log.info(AutoPaySynchConstant.LOG_PREFIX + "Resolving modern customer ID for legacyCustomerId: {}",
				correlationId, legacyCustomerId);
		return convertId(legacyCustomerId, SyncType.LEGACY_TO_MODERN, correlationId);
	}

	@Override
	protected String getMapName(SyncType syncType) {
		return syncType == SyncType.MODERN_TO_LEGACY
				? config.getModernToLegacy().getMapName()
				: config.getLegacyToModern().getMapName();
	}

	@Override
	protected String getKeyName(SyncType syncType) {
		return syncType == SyncType.MODERN_TO_LEGACY
				? config.getModernToLegacy().getKeyName()
				: config.getLegacyToModern().getKeyName();
	}

	@Override
	protected String getEntityType() {
		return "CUSTOMER";
	}

	@Override
	protected Mono<String> processRecord(GenericRecord record, SyncType syncType, String correlationId, String keyName) {
		String customerId = record.getString(keyName);
		if (customerId == null || customerId.trim().isEmpty()) {
			log.warn(AutoPaySynchConstant.LOG_PREFIX + "Customer ID is null or empty for keyName '{}' for {}",
					correlationId, keyName, syncType);
			return Mono.empty();
		}
		log.info(AutoPaySynchConstant.LOG_PREFIX + "Successfully retrieved customer ID for {} from Hazelcast: {}",
				correlationId, syncType, customerId);
		return Mono.just(customerId.trim());
	}

	@Override
	protected Mono<String> callExternalService(String key, SyncType syncType, String correlationId) {
		log.info(AutoPaySynchConstant.LOG_PREFIX
				+ "Falling back to Customer Domain Service for legacyCustomerId: {}", correlationId, key);

		var headers = Map.of(AutoPaySynchConstant.CORRELATION_ID, correlationId,
				"apiKey", customerDomainApiKey);
		var params = new LinkedMultiValueMap<String, String>();
		params.add("systemCustomerId", key);

		String url = customerDomainHost + systemLinkagesUri;

		return autoPaySyncClientHandler.webClientGet(url, headers, "customer-domain-service", params)
				.bodyToMono(SystemLinkagesResponse.class)
				.doOnNext(response -> log.info(AutoPaySynchConstant.LOG_PREFIX
						+ "Response from Customer Domain Service for legacyCustomerId: {}: {}",
						correlationId, key, response))
				.flatMap(response -> extractModernCustomerId(response, key, correlationId))
				.onErrorResume(err -> {
					log.error(AutoPaySynchConstant.LOG_PREFIX
							+ "Error from Customer Domain Service for legacyCustomerId: {}, Error: {}",
							correlationId, key, err.getMessage());
					return Mono.error(err);
				});
	}

	private Mono<String> extractModernCustomerId(SystemLinkagesResponse response, String legacyCustomerId,
			String correlationId) {
		if (response == null || response.getContent() == null || response.getContent().isEmpty()) {
			return Mono.error(new AutoPaySynchException(
					"No data found from Customer Domain Service for legacyCustomerId: " + legacyCustomerId,
					correlationId));
		}

		List<ContentInner> content = response.getContent();
		return content.stream()
				.filter(Objects::nonNull)
				.map(ContentInner::getIndividualUniqueIdentifier)
				.filter(Objects::nonNull)
				.map(Object::toString)
				.filter(StringUtils::hasText)
				.findFirst()
				.map(Mono::just)
				.orElseGet(() -> {
					log.error(AutoPaySynchConstant.LOG_PREFIX
							+ "No modern customer ID found for legacyCustomerId: {}", correlationId, legacyCustomerId);
					return Mono.error(new AutoPaySynchException(
							"No modern customer ID found for legacyCustomerId: " + legacyCustomerId, correlationId));
				});
	}

}








