@BeforeEach
void setUp() {
	lenient().when(externalServiceConfig.getCiam()).thenReturn(ciamConfig);
	lenient().when(externalServiceConfig.getCreditAccount()).thenReturn(creditAccountConfig);
	lenient().when(externalServiceConfig.getAgentFallback()).thenReturn(agentFallbackConfig);

	lenient().when(ciamConfig.getHost()).thenReturn(CIAM_HOST);
	lenient().when(ciamConfig.getProductsUri()).thenReturn(CIAM_URI);
	lenient().when(ciamConfig.getApikey()).thenReturn("ciam-api-key");

	lenient().when(creditAccountConfig.getHost()).thenReturn(CREDIT_ACCOUNT_HOST);
	lenient().when(creditAccountConfig.getAccountsUri()).thenReturn(CREDIT_ACCOUNT_URI);
	lenient().when(creditAccountConfig.getApikey()).thenReturn("credit-account-api-key");

	lenient().when(agentFallbackConfig.getHost()).thenReturn(AGENT_FALLBACK_HOST);
	lenient().when(agentFallbackConfig.getHazelcastAgentIdFallbackServiceUri()).thenReturn(AGENT_FALLBACK_URI);
	lenient().when(agentFallbackConfig.getApikey()).thenReturn("hazelcast-api-key");

	lenient().when(autoPaySyncClientHandler.get(any(), any(), any(), any()))
			.thenReturn(responseSpec);

	externalCallService = new ExternalCallService(externalServiceConfig, autoPaySyncClientHandler);
}

// ==================== getModernCreditAccountId ====================

@Test
void testGetModernCreditAccountId_Success_ReturnsAccountIdDto() {
	AccountsDetailsResponseContentInner content = new AccountsDetailsResponseContentInner();
	content.setAccountId(ACCOUNT_ID);

	AccountsDetailsResponse response = new AccountsDetailsResponse();
	response.setContent(List.of(content));

	when(responseSpec.bodyToMono(AccountsDetailsResponse.class))
			.thenReturn(Mono.just(response));

	StepVerifier.create(
			externalCallService.getModernCreditAccountId(MODERN_CUSTOMER_ID, CORRELATION_ID))
			.assertNext(dto -> {
				assertNotNull(dto);
				assertEquals(ACCOUNT_ID, dto.getAccountId());
			})
			.verifyComplete();

	verify(autoPaySyncClientHandler).get(
			eq(CREDIT_ACCOUNT_HOST + CREDIT_ACCOUNT_URI), any(), eq("credit-account-service"), any());
}

@Test
void testGetModernCreditAccountId_WhenNullResponse_ThrowsException() {
	AccountsDetailsResponse response = new AccountsDetailsResponse();
	response.setContent(null);

	when(responseSpec.bodyToMono(AccountsDetailsResponse.class))
			.thenReturn(Mono.just(response));

	StepVerifier.create(
			externalCallService.getModernCreditAccountId(MODERN_CUSTOMER_ID, CORRELATION_ID))
			.expectError(AutoPaySynchException.class)
			.verify();
}

