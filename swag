<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>
	<groupId>com.creditone.ucrm.autopaysynch</groupId>
	<artifactId>auto-pay-config-sync-service</artifactId>
	<version>0.0.1-SNAPSHOT</version>
	<name></name>
	<description></description>

	<parent>
        <!--Automation script will patch the version in case of vulnerability discovery-->
        <groupId>com.creditone.microservice</groupId>
        <artifactId>reactive-microservice-starter-parent</artifactId>
        <version>3.0.0</version>
        <relativePath/>
    </parent>

	<properties>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <java.version>21</java.version>
    </properties>

	<dependencies>
		<dependency>
            <groupId>com.creditone.microservice</groupId>
            <artifactId>reactive-microservice-common-starter</artifactId>
            <exclusions>
                <exclusion>
                    <groupId>org.springframework.boot</groupId>
                    <artifactId>spring-boot-starter-security</artifactId>
                </exclusion>
                <exclusion>
                    <groupId>org.springframework.cloud</groupId>
                    <artifactId>spring-cloud-starter-vault-config</artifactId>
                </exclusion>
            </exclusions>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-logging</artifactId>
            <version>3.5.7</version>
            <exclusions>
                <exclusion>
                    <groupId>org.apache.logging.log4j</groupId>
                    <artifactId>log4j-to-slf4j</artifactId>
                </exclusion>
            </exclusions>
        </dependency>
        <dependency>
            <groupId>jakarta.annotation</groupId>
            <artifactId>jakarta.annotation-api</artifactId>
            <version>3.0.0</version>
			<scope>provided</scope>
        </dependency>
        <dependency>
            <groupId>io.projectreactor</groupId>
            <artifactId>reactor-test</artifactId>
            <version>3.7.13</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-databind</artifactId>
            <version>2.19.4</version>
        </dependency>
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-core</artifactId>
            <version>2.19.4</version>
        </dependency>
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-annotations</artifactId>
            <version>2.19.4</version>
        </dependency>
        <dependency>
            <groupId>org.aspectj</groupId>
            <artifactId>aspectjweaver</artifactId>
            <version>1.9.25</version>
        </dependency>
        <dependency>
            <groupId>org.postgresql</groupId>
            <artifactId>postgresql</artifactId>
            <version>42.7.8</version>
        </dependency>
        <dependency>
            <groupId>io.hypersistence</groupId>
            <artifactId>hypersistence-utils-hibernate-63</artifactId>
            <version>3.12.0</version>
        </dependency>
        <dependency>
            <groupId>org.kie</groupId>
            <artifactId>kie-ci</artifactId>
            <version>10.1.0</version>
            <exclusions>
                <exclusion>
                    <groupId>org.slf4j</groupId>
                    <artifactId>slf4j-api</artifactId>
                </exclusion>
            </exclusions>
        </dependency>
        <dependency>
            <groupId>com.hazelcast</groupId>
            <artifactId>hazelcast</artifactId>
            <version>5.5.0</version>
        </dependency>
        <dependency>
            <groupId>com.hazelcast</groupId>
            <artifactId>hazelcast-enterprise</artifactId>
            <version>5.5.0</version>
        </dependency>
	</dependencies>

	<build>
		<resources>
            <resource>
                <filtering>true</filtering>
                <directory>src/main/resources</directory>
                <includes>
                    <include>**/*.properties</include>
                    <include>**/*.json</include>
                </includes>
            </resource>
        </resources>
		<plugins>
			<plugin>
				<groupId>org.openapitools</groupId>
				<artifactId>openapi-generator-maven-plugin</artifactId>
				<version>6.6.0</version>
				<executions>
					<execution>
						<?m2e execute onConfiguration,onIncremental?>
						<id>ciam</id>
						<goals>
							<goal>generate</goal>
						</goals>
						<configuration>
							<inputSpec>${project.basedir}/src/main/resources/swagger/ciam/ciam.yml</inputSpec>
							<output>${project.build.directory}/generated-sources/swagger</output>
							<apiPackage></apiPackage>
							<invokerPackage></invokerPackage>
							<modelPackage>com.creditone.swagger.ciam.dtoswagger</modelPackage>
							<apisToGenerate>false</apisToGenerate>
							<generateApiTests>false</generateApiTests>
							<generateSupportingFiles>false</generateSupportingFiles>
							<generateModelTests>false</generateModelTests>
							<skipValidateSpec>true</skipValidateSpec>
							<library>resttemplate</library>
							<generatorName>java</generatorName>
							<configOptions>
								<sourceFolder>src/main/java</sourceFolder>
								<dateLibrary>java8</dateLibrary>
								<enable303>true</enable303>
								<useBeanValidation>true</useBeanValidation>
								<serializableModel>true</serializableModel>
								<reactive>true</reactive>
								<responseWrapper>reactor.core.publisher.Mono</responseWrapper>
								<useJakartaEe>true</useJakartaEe>
								<openApiNullable>false</openApiNullable>
							</configOptions>
						</configuration>
					</execution>
					<execution>
						<?m2e execute onConfiguration,onIncremental?>
						<id>credit-account-service</id>
						<goals>
							<goal>generate</goal>
						</goals>
						<configuration>
							<inputSpec>${project.basedir}/src/main/resources/swagger/credit-account-service/credit-account-service.yml</inputSpec>
							<output>${project.build.directory}/generated-sources/swagger</output>
							<apiPackage></apiPackage>
							<invokerPackage></invokerPackage>
							<modelPackage>com.creditone.swagger.creditaccountservice.dtoswagger</modelPackage>
							<apisToGenerate>false</apisToGenerate>
							<generateApiTests>false</generateApiTests>
							<generateSupportingFiles>false</generateSupportingFiles>
							<generateModelTests>false</generateModelTests>
							<skipValidateSpec>true</skipValidateSpec>
							<library>resttemplate</library>
							<generatorName>java</generatorName>
							<configOptions>
								<sourceFolder>src/main/java</sourceFolder>
								<dateLibrary>java8</dateLibrary>
								<enable303>true</enable303>
								<useBeanValidation>true</useBeanValidation>
								<serializableModel>true</serializableModel>
								<reactive>true</reactive>
								<responseWrapper>reactor.core.publisher.Mono</responseWrapper>
								<useJakartaEe>true</useJakartaEe>
								<openApiNullable>false</openApiNullable>
							</configOptions>
						</configuration>
					</execution>
					<execution>
						<?m2e execute onConfiguration,onIncremental?>
						<id>creditcard-extaccounts-agentid-fallback-service-api</id>
						<goals>
							<goal>generate</goal>
						</goals>
						<configuration>
							<inputSpec>${project.basedir}/src/main/resources/swagger/agentidfallbackservice/agentid-fallback-service.yaml</inputSpec>
							<output>${project.build.directory}/generated-sources/swagger</output>
							<apiPackage></apiPackage>
							<invokerPackage></invokerPackage>
							<modelPackage>com.creditone.swagger.agentidfallbackservice.dtoswagger</modelPackage>
							<apisToGenerate>false</apisToGenerate>
							<generateApiTests>false</generateApiTests>
							<generateSupportingFiles>false</generateSupportingFiles>
							<generateModelTests>false</generateModelTests>
							<skipValidateSpec>true</skipValidateSpec>
							<library>resttemplate</library>
							<generatorName>java</generatorName>
							<configOptions>
								<sourceFolder>src/main/java</sourceFolder>
								<dateLibrary>java8</dateLibrary>
								<enable303>true</enable303>
								<useBeanValidation>true</useBeanValidation>
								<serializableModel>true</serializableModel>
								<reactive>true</reactive>
								<responseWrapper>reactor.core.publisher.Mono</responseWrapper>
								<useJakartaEe>true</useJakartaEe>
								<openApiNullable>false</openApiNullable>
							</configOptions>
						</configuration>
					</execution>
					<execution>
						<?m2e execute onConfiguration,onIncremental?>
						<id>auto-pay-config-sync-service</id>
						<goals>
							<goal>generate</goal>
						</goals>
						<configuration>
							<inputSpec>${project.basedir}/src/main/resources/swagger/autopayconfigsyncservice/auto-pay-config-sync-service.yaml</inputSpec>
							<output>${project.build.directory}/generated-sources/swagger</output>
							<apiPackage></apiPackage>
							<invokerPackage></invokerPackage>
							<modelPackage>com.creditone.swagger.autopayconfigsyncservice.dtoswagger</modelPackage>
							<apisToGenerate>false</apisToGenerate>
							<generateApiTests>false</generateApiTests>
							<generateSupportingFiles>false</generateSupportingFiles>
							<generateModelTests>false</generateModelTests>
							<skipValidateSpec>true</skipValidateSpec>
							<library>resttemplate</library>
							<generatorName>java</generatorName>
							<configOptions>
								<sourceFolder>src/main/java</sourceFolder>
								<dateLibrary>java8</dateLibrary>
								<enable303>true</enable303>
								<useBeanValidation>true</useBeanValidation>
								<serializableModel>true</serializableModel>
								<reactive>true</reactive>
								<responseWrapper>reactor.core.publisher.Mono</responseWrapper>
								<useJakartaEe>true</useJakartaEe>
								<openApiNullable>false</openApiNullable>
							</configOptions>
						</configuration>
					</execution>
				</executions>
			</plugin>
			<!--  Plugin configurations are inherited from parent-->
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
                <configuration>
                    <addResources>true</addResources>
                </configuration>
            </plugin>
            <plugin>
                <!-- Building an executable jar -->
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-jar-plugin</artifactId>
                <configuration>
                    <archive>
                        <manifest>
                            <mainClass>com.creditone.ucrm.autopaysynch.Application</mainClass>
                        </manifest>
                    </archive>
                </configuration>
            </plugin>
            <!-- Plugins for Junit mvn test and Jacoco starts -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-failsafe-plugin</artifactId>
            </plugin>

            <plugin>
                <groupId>org.jacoco</groupId>
                <artifactId>jacoco-maven-plugin</artifactId>
                <configuration>
                    <excludes>
                        <exclude>**/*com/creditone/ucrm/autopaysynch/Application.class</exclude>
                        <exclude>**/*com/creditone/swagger/**</exclude>
                    </excludes>
                </configuration>
            </plugin>

            <!-- Plugins for Junit mvn test and Jacoco ends -->
            <plugin>
                <groupId>com.diffplug.spotless</groupId>
                <artifactId>spotless-maven-plugin</artifactId>
                <version>3.0.0</version>
                <configuration>
                    <java>
                        <includes>
                            <include>src/main/java/**/*.java</include>
                            <include>src/test/java/**/*.java</include>
                        </includes>
                        <excludes>
                            <exclude>target/generated-sources/**/*.java</exclude>
                            <exclude>src/main/java/**/generated/**/*.java</exclude>
                        </excludes>
                        <importOrder>
                            <order>
                                java|javax,jakarta,org.springframework,org,com,com.creditone,,\#</order>
                        </importOrder>
                        <eclipse>
					        <file>${project.basedir}/code-formatter.xml</file>
					    </eclipse>
                        <removeUnusedImports />
                        <replace>
                            <name>Remove extra blank lines</name>
                            <search>\n\n\n+</search>
                            <replacement>\n\n</replacement>
                        </replace>
                        <trimTrailingWhitespace />
                        <endWithNewline />
                    </java>
                    <formats>
                        <format>
						    <includes>
						        <include>src/main/resources/**/*.yml</include>
						        <include>src/main/resources/**/*.yaml</include>
						        <include>src/test/resources/**/*.yml</include>
						        <include>src/test/resources/**/*.yaml</include>
						    </includes>
						    <trimTrailingWhitespace />
						    <endWithNewline />
						    <indent>
						        <spaces>true</spaces>
						        <spacesPerTab>2</spacesPerTab>
						    </indent>
						</format>
                        <format>
                            <includes>
                                <include>src/main/resources/**/*.properties</include>
                                <include>src/test/resources/**/*.properties</include>
                            </includes>
                            <trimTrailingWhitespace />
                            <endWithNewline />
                        </format>
                    </formats>
                </configuration>
                <executions>
                    <execution>
                        <id>spotless-apply</id>
                        <goals>
                            <goal>apply</goal>
                        </goals>
                        <phase>process-sources</phase>
                    </execution>
                </executions>
            </plugin>
            <plugin>
			    <groupId>org.apache.maven.plugins</groupId>
			    <artifactId>maven-compiler-plugin</artifactId>
			    <configuration>
			        <annotationProcessorPaths>
			            <path>
			                <groupId>org.projectlombok</groupId>
			                <artifactId>lombok</artifactId>
			                <version>1.18.42</version>
			            </path>
			        </annotationProcessorPaths>
			    </configuration>
			</plugin>
		</plugins>
	</build>

	<repositories>
        <repository>
            <!--All packages needed can be found at Development Group-->
            <id>gitlab-maven</id>
            <url>https://gitlab.com/api/v4/groups/13452711/-/packages/maven</url>
            <releases>
                <enabled>true</enabled>
            </releases>
            <snapshots>
                <enabled>true</enabled>
            </snapshots>
        </repository>
        <repository>
            <id>sona-hazelcast</id>
            <url>https://sona-artifacts.c1b.corp/repository/maven-hazelcast/</url>
            <releases>
                <enabled>true</enabled>
            </releases>
            <snapshots>
                <enabled>true</enabled>
            </snapshots>
        </repository>
    </repositories>
</project>
