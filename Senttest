	StepVerifier.create(
			customerMappingProcessor.getModernCustomerId(LEGACY_CUSTOMER_ID, CORRELATION_ID))
			.expectError(AutoPaySynchException.class)
			.verify();
}

@Test
void testGetModernCustomerId_WhenExternalServiceReturnsEmpty_ReturnsError() {
	when(hazelcastWrapperProcessor.getRecord(LTM_MAP_NAME, LEGACY_CUSTOMER_ID, CORRELATION_ID))
			.thenReturn(null);
	when(externalCallService.convertCustomerId(
			LEGACY_CUSTOMER_ID, SyncType.LEGACY_TO_MODERN, CORRELATION_ID))
			.thenReturn(Mono.empty());

	StepVerifier.create(
			customerMappingProcessor.getModernCustomerId(LEGACY_CUSTOMER_ID, CORRELATION_ID))
			.verifyComplete();
}

// ==================== getMapName ====================

@Test
void testGetMapName_LegacyToModern_ReturnsLtmMapName() {
	String mapName = customerMappingProcessor.getMapName(SyncType.LEGACY_TO_MODERN);
	assertEquals(LTM_MAP_NAME, mapName);
}

@Test
void testGetMapName_ModernToLegacy_ReturnsMtlMapName() {
	String mapName = customerMappingProcessor.getMapName(SyncType.MODERN_TO_LEGACY);
	assertEquals(MTL_MAP_NAME, mapName);
}

// ==================== getKeyName ====================

@Test
void testGetKeyName_LegacyToModern_ReturnsLtmKeyName() {
	String keyName = customerMappingProcessor.getKeyName(SyncType.LEGACY_TO_MODERN);
	assertEquals(LTM_KEY_NAME, keyName);
}

@Test
void testGetKeyName_ModernToLegacy_ReturnsMtlKeyName() {
	String keyName = customerMappingProcessor.getKeyName(SyncType.MODERN_TO_LEGACY);
	assertEquals(MTL_KEY_NAME, keyName);
}

