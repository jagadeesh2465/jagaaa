	content.setAccountId(ACCOUNT_ID);

	AccountsDetailsResponse response = new AccountsDetailsResponse();
	response.setContent(List.of(content));

	when(responseSpec.bodyToMono(AccountsDetailsResponse.class))
			.thenReturn(Mono.just(response));

	StepVerifier.create(
			externalCallService.getModernCreditAccountId(MODERN_CUSTOMER_ID, CORRELATION_ID))
			.assertNext(dto -> {
				assertNotNull(dto);
				assertEquals(ACCOUNT_ID, dto.getAccountId());
			})
			.verifyComplete();

	verify(autoPaySyncClientHandler).get(
			eq(CREDIT_ACCOUNT_HOST + CREDIT_ACCOUNT_URI), any(), eq("credit-account-service"), any());
}

