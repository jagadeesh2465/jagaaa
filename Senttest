private ExternalCallService.ExternalServiceConfig.CiamConfig ciamConfig;

@Mock
private ExternalCallService.ExternalServiceConfig.CreditAccountConfig creditAccountConfig;

@Mock
private ExternalCallService.ExternalServiceConfig.HazelcastConfig hazelcastConfig;

@Mock
private WebClient.ResponseSpec responseSpec;

private ExternalCallService externalCallService;

private static final String CORRELATION_ID = "corr-test-001";
private static final String MODERN_CUSTOMER_ID = "uuid-customer-abc-123";
private static final String LEGACY_CUSTOMER_ID = "12345";
