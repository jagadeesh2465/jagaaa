import org.mockito.junit.jupiter.MockitoSettings;
import org.mockito.quality.Strictness;

import com.hazelcast.core.HazelcastInstance;
import com.hazelcast.map.IMap;
import com.hazelcast.nio.serialization.genericrecord.GenericRecord;

@ExtendWith(MockitoExtension.class)
@MockitoSettings(strictness = Strictness.LENIENT)
class HazelcastWrapperProcessorTest {

```
@Mock
private HazelcastInstance hazelcastInstance;

@Mock
private IMap<String, GenericRecord> map;

@Mock
private GenericRecord genericRecord;

private HazelcastWrapperProcessor hazelcastWrapperProcessor;

private static final String MAP_NAME = "AUTOPAY_CUSTOMER_LTM_MAP";
private static final String KEY = "12345";
private static final String CORRELATION_ID = "corr-test-001";

@BeforeEach
void setUp() {
	hazelcastWrapperProcessor = new HazelcastWrapperProcessor(hazelcastInstance);
}

// ==================== getRecord ====================

@Test
void testGetRecord_WhenRecordExists_ReturnsRecord() {
	when(hazelcastInstance.getMap(MAP_NAME)).thenReturn(map);
	when(map.get(KEY)).thenReturn(genericRecord);

	GenericRecord result = hazelcastWrapperProcessor.getRecord(MAP_NAME, KEY, CORRELATION_ID);

	assertNotNull(result);
	assertEquals(genericRecord, result);
	verify(hazelcastInstance).getMap(MAP_NAME);
	verify(map).get(KEY);
}

@Test
void testGetRecord_WhenRecordNotFound_ReturnsNull() {
	when(hazelcastInstance.getMap(MAP_NAME)).thenReturn(map);
	when(map.get(KEY)).thenReturn(null);

	GenericRecord result = hazelcastWrapperProcessor.getRecord(MAP_NAME, KEY, CORRELATION_ID);

	assertNull(result);
	verify(map).get(KEY);
}

@Test
void testGetRecord_WhenMapNotFound_ReturnsNull() {
	when(hazelcastInstance.getMap(MAP_NAME)).thenReturn(null);

	GenericRecord result = hazelcastWrapperProcessor.getRecord(MAP_NAME, KEY, CORRELATION_ID);

	assertNull(result);
	verify(hazelcastInstance).getMap(MAP_NAME);
	verify(map, never()).get(any());
}

@Test
void testGetRecord_WhenHazelcastThrowsException_ReturnsNull() {
	when(hazelcastInstance.getMap(MAP_NAME))
			.thenThrow(new RuntimeException("Hazelcast unavailable"));

	GenericRecord result = hazelcastWrapperProcessor.getRecord(MAP_NAME, KEY, CORRELATION_ID);

	assertNull(result);
}

@Test
void testGetRecord_WhenMapGetThrowsException_ReturnsNull() {
	when(hazelcastInstance.getMap(MAP_NAME)).thenReturn(map);
	when(map.get(KEY)).thenThrow(new RuntimeException("Map get failed"));

	GenericRecord result = hazelcastWrapperProcessor.getRecord(MAP_NAME, KEY, CORRELATION_ID);

	assertNull(result);
}

@Test
void testGetRecord_WithDifferentMapNames_UsesCorrectMap() {
	String agentMapName = "AUTOPAY_AGENT_LTM_MAP";
	IMap<String, GenericRecord> agentMap = mock(IMap.class);

	when(hazelcastInstance.getMap(agentMapName)).thenReturn(agentMap);
	when(agentMap.get(KEY)).thenReturn(genericRecord);

	GenericRecord result = hazelcastWrapperProcessor.getRecord(agentMapName, KEY, CORRELATION_ID);

	assertNotNull(result);
	verify(hazelcastInstance).getMap(agentMapName);
	verify(agentMap).get(KEY);
}

@Test
void testGetRecord_WithNullCorrelationId_DoesNotThrow() {
	when(hazelcastInstance.getMap(MAP_NAME)).thenReturn(map);
	when(map.get(KEY)).thenReturn(genericRecord);

	assertDoesNotThrow(() ->
			hazelcastWrapperProcessor.getRecord(MAP_NAME, KEY, null));
}
