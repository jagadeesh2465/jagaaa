void testGetModernCustomerId_WhenHazelcastHit_ReturnsModernId() {
	when(hazelcastWrapperProcessor.getRecord(LTM_MAP_NAME, LEGACY_CUSTOMER_ID, CORRELATION_ID))
			.thenReturn(genericRecord);
	when(genericRecord.getString(LTM_KEY_NAME)).thenReturn(MODERN_CUSTOMER_UUID);

	StepVerifier.create(
			customerMappingProcessor.getModernCustomerId(LEGACY_CUSTOMER_ID, CORRELATION_ID))
			.expectNext(MODERN_CUSTOMER_UUID)
			.verifyComplete();

	verify(externalCallService, never()).convertCustomerId(any(), any(), any());
}

@Test
void testGetModernCustomerId_WhenHazelcastMiss_CallsExternalService() {
	when(hazelcastWrapperProcessor.getRecord(LTM_MAP_NAME, LEGACY_CUSTOMER_ID, CORRELATION_ID))
			.thenReturn(null);
	when(externalCallService.convertCustomerId(
			LEGACY_CUSTOMER_ID, SyncType.LEGACY_TO_MODERN, CORRELATION_ID))
			.thenReturn(Mono.just(MODERN_CUSTOMER_UUID));

	StepVerifier.create(
			customerMappingProcessor.getModernCustomerId(LEGACY_CUSTOMER_ID, CORRELATION_ID))
			.expectNext(MODERN_CUSTOMER_UUID)
			.verifyComplete();

	verify(externalCallService, times(1))
			.convertCustomerId(LEGACY_CUSTOMER_ID, SyncType.LEGACY_TO_MODERN, CORRELATION_ID);
}

@Test
void testGetModernCustomerId_WhenHazelcastRecordEmpty_FallsBackToExternalService() {
	when(hazelcastWrapperProcessor.getRecord(LTM_MAP_NAME, LEGACY_CUSTOMER_ID, CORRELATION_ID))
			.thenReturn(genericRecord);
	when(genericRecord.getString(LTM_KEY_NAME)).thenReturn(null);
	when(externalCallService.convertCustomerId(
			LEGACY_CUSTOMER_ID, SyncType.LEGACY_TO_MODERN, CORRELATION_ID))
			.thenReturn(Mono.just(MODERN_CUSTOMER_UUID));

	StepVerifier.create(
			customerMappingProcessor.getModernCustomerId(LEGACY_CUSTOMER_ID, CORRELATION_ID))
			.expectNext(MODERN_CUSTOMER_UUID)
			.verifyComplete();

	verify(externalCallService, times(1))
			.convertCustomerId(LEGACY_CUSTOMER_ID, SyncType.LEGACY_TO_MODERN, CORRELATION_ID);
}

@Test
void testGetModernCustomerId_WhenBothFail_ReturnsError() {
	when(hazelcastWrapperProcessor.getRecord(LTM_MAP_NAME, LEGACY_CUSTOMER_ID, CORRELATION_ID))
			.thenReturn(null);
