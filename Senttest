	lenient().when(externalServiceConfig.getHazelcast()).thenReturn(hazelcastConfig);

	lenient().when(ciamConfig.getHost()).thenReturn(CIAM_HOST);
	lenient().when(ciamConfig.getProductsUri()).thenReturn(CIAM_URI);
	lenient().when(ciamConfig.getApikey()).thenReturn("ciam-api-key");

